# Application
APP_NAME=UNTOLD API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://untold:untold_secret@localhost:5432/untold_db

# JWT — generate with: openssl rand -hex 32
# Required in production (min 32 chars, no placeholder values)
SECRET_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate limiting (Redis-backed)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database seeding (development only — disabled in production by default)
SEED_DATABASE=true
ADMIN_EMAIL=admin@untold.com
# Required when SEED_DATABASE=true (min 12 chars in production)
ADMIN_PASSWORD=your-local-dev-password

# News engine — AI & external sources (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SPORTMONKS_API_KEY=
SPORTRADAR_API_KEY=
CRICAPI_API_KEY=
NEWS_FETCH_INTERVAL_MINUTES=15
LIVE_SYNC_INTERVAL_SECONDS=30

# Payments — Stripe & Razorpay
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# OTT / S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
CDN_BASE_URL=
STREAM_URL_EXPIRE_SECONDS=3600
