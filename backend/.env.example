# Application
APP_NAME=UNTOLD API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://untold:untold_secret@localhost:5432/untold_db

# JWT — generate with: openssl rand -hex 32
# Required in production (min 32 chars, no placeholder values)
SECRET_KEY=

# Field encryption for enterprise secrets vault (optional — falls back to SECRET_KEY if unset)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate limiting (Redis-backed)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Trusted hosts — use explicit hostnames in production (never *)
TRUSTED_HOSTS=*

# Google OAuth (Studio login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STUDIO_ALLOWED_EMAIL_DOMAINS=

# SMTP (password reset, contact confirmations)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_PATH=/reset-password

# Database seeding (development only — disabled in production by default)
SEED_DATABASE=true
ADMIN_EMAIL=admin@untold.com
# Required when SEED_DATABASE=true (min 12 chars in production)
ADMIN_PASSWORD=your-local-dev-password

# News engine — AI & external sources (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SPORTMONKS_API_KEY=
SPORTRADAR_API_KEY=
CRICAPI_API_KEY=
NEWS_FETCH_INTERVAL_MINUTES=15
LIVE_SYNC_INTERVAL_SECONDS=30

# Payments — Stripe & Razorpay
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_PRICE_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Studio security (Phase 1)
AI_ALLOW_DEMO_IN_PRODUCTION=false
WORKFLOW_EVENT_SECRET=
LIVE_WEBHOOK_SECRET=
SSO_ALLOWED_REDIRECT_URIS=https://studio.untold.com/studio/login,https://untold.com/login
MAX_UPLOAD_BYTES=52428800

# OTT / S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
CDN_BASE_URL=
STREAM_URL_EXPIRE_SECONDS=3600

# Observability (Prometheus / OpenTelemetry)
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=untold-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
