# UNTOLD — environment for local development
# Production: use deploy/env/production.env.example

VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000

# Docker full-stack: cp deploy/env/development.env.example .env && docker compose up -d
# Web via nginx: http://localhost:8080 | API proxied at /api/v1 (relative URL in web image)
