# UNTOLD — global production (extends production.env.example)
# Use with regional K8s overlays + Cloudflare edge

ENVIRONMENT=production
DEBUG=false

# --- Cloudflare / CDN ---
CDN_BASE_URL=https://cdn.untold.com
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=untold-media
S3_REGION=auto
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY via secrets

# --- Multi-region database ---
# Primary (writes) — EU cluster only
DATABASE_URL=postgresql://untold:SECRET@pg-primary.eu.internal:5432/untold_db
# Read replica — optional; US overlay uses replica endpoint
# DATABASE_READ_URL=postgresql://untold:SECRET@pg-replica.us.internal:5432/untold_db

# --- Redis (regional; use Global Database or replica per region) ---
REDIS_URL=redis://redis.eu.internal:6379/0
CELERY_BROKER_URL=redis://redis.eu.internal:6379/1
CELERY_RESULT_BACKEND=redis://redis.eu.internal:6379/2

# --- Hosts (Cloudflare proxied) ---
CORS_ORIGINS=https://untold.com,https://www.untold.com,https://studio.untold.com,https://developers.untold.com
TRUSTED_HOSTS=untold.com,www.untold.com,api.untold.com,studio.untold.com,developers.untold.com

VITE_API_URL=https://api.untold.com/api/v1

# --- Observability ---
LOG_FORMAT=json
METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability.svc:4318
OTEL_SERVICE_NAME=untold-api
# OTEL_RESOURCE_ATTRIBUTES=deployment.region=eu-west-1

# --- Backups (cross-region vault) ---
BACKUP_RETENTION_DAYS=30
BACKUP_S3_URI=s3://untold-dr-vault/backups/postgres
# WAL archive: configure on managed Postgres provider

# --- Rate limits (origin; edge adds additional CF limits) ---
RATE_LIMIT_ENABLED=true

# --- Regional metadata (set per overlay) ---
# UNTOLD_REGION=eu-west-1
# UNTOLD_DEPLOYMENT_ROLE=primary

SEED_DATABASE=false
RUN_MIGRATIONS=true
