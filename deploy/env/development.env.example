# UNTOLD — development environment
# Copy to repo root: cp deploy/env/development.env.example .env

# === Core ===
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32-in-prod
# Optional — separate Fernet key for enterprise secrets vault
ENCRYPTION_KEY=dev-only-encryption-key-32chars-min

# === Ports (docker compose — host bindings) ===
API_PORT=8000
WEB_PORT=8080
# db/redis are internal to the compose network (no host publish by default).
# Local non-Docker dev uses backend/.env with localhost:5432 / localhost:6379.

# === Database ===
POSTGRES_USER=untold
POSTGRES_PASSWORD=untold_secret
POSTGRES_DB=untold_db
DATABASE_URL=postgresql://untold:untold_secret@db:5432/untold_db

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === API ===
CORS_ORIGINS=https://www.untoldoriginals.blog,https://untoldoriginals.blog,http://localhost:8080,http://localhost:5173,http://localhost:3000
RATE_LIMIT_ENABLED=true
SEED_DATABASE=true
ADMIN_EMAIL=admin@untold.com
ADMIN_PASSWORD=ChangeMe123!

# === Frontend ===
VITE_API_URL=/api/v1

# === Observability ===
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=untold-api

# === Monitoring (optional profile) ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=untold_grafana
