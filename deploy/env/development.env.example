# UNTOLD — development environment
# Copy to repo root: cp deploy/env/development.env.example .env

# === Core ===
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32-in-prod
# Optional — separate key for Fernet encryption of enterprise secrets (recommended in production)
ENCRYPTION_KEY=

# === Ports (docker compose) ===
API_PORT=8000
WEB_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

# === Database ===
POSTGRES_USER=untold
POSTGRES_PASSWORD=untold_secret
POSTGRES_DB=untold_db
DATABASE_URL=postgresql://untold:untold_secret@db:5432/untold_db

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === API ===
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000
RATE_LIMIT_ENABLED=true
SEED_DATABASE=true
ADMIN_EMAIL=admin@untold.com
ADMIN_PASSWORD=ChangeMe123!

# === Frontend ===
VITE_API_URL=/api/v1

# === Observability ===
METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=untold-api

# === Monitoring (optional profile) ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=untold_grafana
