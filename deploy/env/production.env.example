# UNTOLD — production environment
# Copy to repo root: cp deploy/env/production.env.example .env
# Generate secrets: openssl rand -hex 32
# NEVER commit filled production secrets to git

ENVIRONMENT=production
DEBUG=false
SECRET_KEY=
ENCRYPTION_KEY=

POSTGRES_USER=untold
POSTGRES_PASSWORD=
POSTGRES_DB=untold_db
DATABASE_URL=postgresql://untold:CHANGE_ME@db:5432/untold_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CORS_ORIGINS=https://www.untoldoriginals.blog,https://untoldoriginals.blog,http://localhost:8080,http://localhost:5173,http://localhost:3000
TRUSTED_HOSTS=www.untoldoriginals.blog,untoldoriginals.blog,localhost,127.0.0.1,api
SEED_DATABASE=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AI=30/minute
RUN_MIGRATIONS=true
ENABLE_WEBSOCKET=true

VITE_API_URL=/api/v1

# AI providers — required in production (demo providers blocked by config validation)
AI_DEFAULT_PROVIDER=openai
EMBEDDINGS_DEFAULT_PROVIDER=openai
VECTORSTORE_DEFAULT_PROVIDER=pgvector
IMAGE_DEFAULT_PROVIDER=openai_images
VIDEO_DEFAULT_PROVIDER=runway
VOICE_DEFAULT_PROVIDER=elevenlabs
MUSIC_DEFAULT_PROVIDER=suno
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=

# File uploads / OTT media — use S3 or Cloudflare R2 in production
STORAGE_DEFAULT_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT_URL=
CDN_BASE_URL=

# Observability — set OTEL_ENABLED=true when using docker-compose.monitoring.yml
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=untold-api

# Backups — optional S3 off-site copy (profile: backup)
BACKUP_RETENTION_DAYS=30
# BACKUP_S3_URI=s3://your-bucket/untold-backups

LOG_FORMAT=json

# Grafana (monitoring profile)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payments — configure at least one provider for membership checkout
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_PRICE_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMTP & frontend (password reset, contact)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
FRONTEND_URL=https://untold.com
PASSWORD_RESET_PATH=/reset-password

# Studio security
AI_ALLOW_DEMO_IN_PRODUCTION=false
WORKFLOW_EVENT_SECRET=
LIVE_WEBHOOK_SECRET=
SSO_ALLOWED_REDIRECT_URIS=https://studio.untold.com/studio/login,https://untold.com/login
MAX_UPLOAD_BYTES=52428800

# Live sports data (optional)
SPORTMONKS_API_KEY=
SPORTRADAR_API_KEY=
CRICAPI_API_KEY=
