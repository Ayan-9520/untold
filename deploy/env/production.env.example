# UNTOLD — production environment
# NEVER commit filled production secrets to git

ENVIRONMENT=production
DEBUG=false
SECRET_KEY=
ENCRYPTION_KEY=

POSTGRES_USER=untold
POSTGRES_PASSWORD=
POSTGRES_DB=untold_db
DATABASE_URL=

REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

CORS_ORIGINS=https://studio.untold.com,https://untold.com
TRUSTED_HOSTS=studio.untold.com,untold.com,api.untold.com
SEED_DATABASE=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AI=30/minute
RUN_MIGRATIONS=true

VITE_API_URL=/api/v1

METRICS_ENABLED=true
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=untold-api

# Backups — optional S3 off-site copy (requires aws CLI in backup container image)
BACKUP_RETENTION_DAYS=30
# BACKUP_S3_URI=s3://your-bucket/untold-backups

# Logging
LOG_FORMAT=json

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Optional integrations (see backend/.env.example)
GOOGLE_CLIENT_ID=
STRIPE_SECRET_KEY=
OPENAI_API_KEY=
